# Supabase - https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 트레이너 관리자 이메일 (이 이메일로 로그인하면 관리자 메뉴 활성화)
NEXT_PUBLIC_ADMIN_EMAIL=trainer@example.com

# 앱 URL (Vercel 배포 후 변경)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 카카오 JavaScript 키 (https://developers.kakao.com)
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key

# Playwright E2E 테스트 계정
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=your_admin_password
E2E_MEMBER_EMAIL=member@example.com
E2E_MEMBER_PASSWORD=your_member_password
